---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Commercial Solar Planning | New Solar Somalia"
  description="Estimate solar system size, savings, roof space, and battery backup for businesses in Mogadishu."
>
  <section class="hero">
    <div class="hero-content">
      <h1>Commercial Solar Planning</h1>
      <p class="lead">
        Estimate solar size, roof requirements, costs, and savings before requesting supplier quotes.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/calculator">Start Calculator</a>
        <a class="button secondary" href="/methodology">Learn How It Works</a>
      </div>
      <p class="trust-note">Free estimate.</p>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Business benefits</p>
      <h2>Why Businesses Choose Solar</h2>
    </div>
    <div class="feature-grid">
      <article class="feature-card">
        <span class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M4 17h16M7 13h10M9 9h6M12 3v3M5.6 5.6l2.1 2.1M18.4 5.6l-2.1 2.1" /></svg>
        </span>
        <h3>Lower Energy Costs</h3>
        <p>Estimate how solar may reduce monthly electricity purchases for your business.</p>
      </article>
      <article class="feature-card">
        <span class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M5 19c4-1 6-4 6-8V5h8v6c0 5-4 8-8 8H5Z" /></svg>
        </span>
        <h3>Reduce Generator Fuel Use</h3>
        <p>Include diesel generator use to understand potential fuel savings.</p>
      </article>
      <article class="feature-card">
        <span class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M12 3 5 6v5c0 4.5 3 8.5 7 10 4-1.5 7-5.5 7-10V6l-7-3Z" /></svg>
        </span>
        <h3>Improve Power Reliability</h3>
        <p>Compare solar and battery options for outages, evening loads, and critical equipment.</p>
      </article>
      <article class="feature-card">
        <span class="card-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M5 4h14v16H5zM8 8h8M8 12h8M8 16h5" /></svg>
        </span>
        <h3>Plan Before You Buy</h3>
        <p>Use a simple estimate before comparing supplier proposals and site visits.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Simple process</p>
      <h2>How It Works</h2>
    </div>
    <div class="step-grid">
      <article class="step-card">
        <span>1</span>
        <h3>Enter your electricity use</h3>
      </article>
      <article class="step-card">
        <span>2</span>
        <h3>Tell us about your roof and budget</h3>
      </article>
      <article class="step-card">
        <span>3</span>
        <h3>Get a solar estimate</h3>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Built for local businesses</p>
      <h2>Who Is This For?</h2>
    </div>
    <div class="audience-grid">
      <article>Shops</article>
      <article>Offices</article>
      <article>Warehouses</article>
      <article>Clinics</article>
      <article>Restaurants</article>
      <article>Hotels</article>
    </div>
  </section>

  <section class="notice-band">
    <div>
      <p class="eyebrow">Methodology preview</p>
      <h2>Transparent assumptions</h2>
      <p>Estimates are based on local solar assumptions, business energy use, roof space, battery options, and system costs.</p>
    </div>
    <a class="button primary" href="/methodology">View Assumptions</a>
  </section>
</BaseLayout>
